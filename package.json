{
  "name": "md-this-page",
  "displayName": ".MD this page",
  "version": "1.0.0",
  "description": "Convert web page to markdown with one click",
  "author": "Adem Kouki <ademkingnew@gmail.com>",
  "scripts": {
    "dev": "plasmo dev",
    "dev:verbose": "plasmo dev --verbose",
    "dev:firefox": "plasmo dev --target=firefox-mv3",
    "build": "plasmo build",
    "build:source": "plasmo build --source-maps",
    "build:chrome": "plasmo build --target=chrome-mv3 --zip",
    "build:firefox": "plasmo build --target=firefox-mv3 --zip --source-maps",
    "package": "plasmo package",
    "build:all": "pnpm run build:chrome && pnpm run build:firefox"
  },
  "dependencies": {
    "@mozilla/readability": "^0.6.0",
    "@types/mozilla-readability": "^0.2.1",
    "markdown-to-jsx": "^9.7.15",
    "plasmo": "0.90.3",
    "react": "18.2.0",
    "react-dom": "18.2.0",
    "turndown": "^7.2.4",
    "turndown-plugin-gfm": "^1.0.2"
  },
  "devDependencies": {
    "@ianvs/prettier-plugin-sort-imports": "4.1.1",
    "@tailwindcss/typography": "^0.5.19",
    "@types/chrome": "0.0.258",
    "@types/node": "20.11.5",
    "@types/react": "18.2.48",
    "@types/react-dom": "18.2.18",
    "autoprefixer": "^10.5.0",
    "postcss": "^8.5.10",
    "prettier": "3.2.4",
    "tailwindcss": "3",
    "typescript": "5.3.3"
  },
  "manifest": {
    "permissions": [
      "activeTab",
      "contextMenus",
      "storage"
    ],
    "commands": {
      "convert-to-markdown": {
        "suggested_key": {
          "default": "Alt+M"
        },
        "description": "Convert current page to Markdown"
      }
    },
    "browser_specific_settings": {
      "gecko": {
        "id": "ademking@md-this-page",
        "data_collection_permissions": {
          "required": [
            "none"
          ]
        }
      }
    }
  }
}